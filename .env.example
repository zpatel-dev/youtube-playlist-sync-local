# Copy to .env and fill in. systemd loads this via EnvironmentFile=.
# (Do not quote values; systemd takes the whole line after '='. Spaces are fine.)

# --- REQUIRED (the app will not start without these) ---
PLAYLIST_URL=https://www.youtube.com/playlist?list=YOUR_PLAYLIST_ID
GEMINI_API_KEY=your_gemini_api_key

# --- Paths on the host ---
OUTPUT_DIRECTORY=/media/pi/500gb hdd/Youtube_Music/playlist_sync_django
YTDLP_PATH=/home/pi/Desktop/py_music_manager/.venv/bin/yt-dlp
PIP_PATH=/home/pi/Desktop/py_music_manager/.venv/bin/pip
PROJECT_BASE_DIR=/home/pi/Desktop/py_music_manager

# --- systemd service name (used by the "Update yt-dlp" button to restart) ---
SYSTEMD_SERVICE=music_manager

# --- Tuning ---
WORKER_THREADS=2           # background job threads inside the web process
WORKER_POLL_SECONDS=2      # how often a worker checks for new jobs (seconds)
WORKER_COOLDOWN_SECONDS=5  # pause after a download/resync (be nice to YouTube)
SSE_POLL_SECONDS=2         # how often the dashboard checks for changes (seconds)
SYNC_INTERVAL_MINUTES=30   # auto-sync + download every N minutes; 0 = off
DJANGO_LOG_LEVEL=INFO
